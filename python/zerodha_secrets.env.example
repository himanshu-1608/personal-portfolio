# Copy this file to  zerodha_secrets.env  (same dir) and fill in real values.
# That real file is gitignored. After creating it, lock it down:
#     chmod 600 python/zerodha_secrets.env
#
# ZERODHA_TOTP_SECRET is the base32 secret you saved when enrolling Google
# Authenticator (the "enter manually" / "can't scan QR" string), NOT a 6-digit code.

ZERODHA_USER_ID=YOUR_CLIENT_ID
ZERODHA_PASSWORD=YOUR_PASSWORD
ZERODHA_TOTP_SECRET=YOURBASE32SECRET

# Set to 0 for the first run so you can watch the browser and fix selectors.
HEADLESS=1
